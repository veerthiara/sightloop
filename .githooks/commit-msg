#!/bin/sh

set -eu

. "$(dirname "$0")/common.sh"

validate_branch_name

branch="$(branch_name)"

if [ -z "$branch" ] || [ "$branch" = "main" ]; then
    exit 0
fi

message_file="$1"
subject="$(sed -n '1p' "$message_file")"
prefix_regex="$(phase_commit_prefix_regex "$branch")"

case "$subject" in
    Merge\ *|Revert\ *|fixup!\ *|squash!\ *)
        exit 0
        ;;
esac

if printf '%s\n' "$subject" | grep -Eq "$prefix_regex"; then
    exit 0
fi

phase_padded="$(printf '%s\n' "$branch" | sed -E 's/^phase-([0-9]{2})-.*/\1/')"
phase_plain="$(printf '%s\n' "$phase_padded" | sed -E 's/^0*([0-9]+)$/\1/')"
rev="$(printf '%s\n' "$branch" | sed -E 's/.*-rev-([0-9]{2})$/\1/')"

if [ -z "$phase_plain" ]; then
    phase_plain="0"
fi

cat >&2 <<EOF
Commit message does not match branch revision.

Branch:
  $branch

Expected subject format:
  phase-$phase_plain rev-$rev: short summary

Examples:
  phase-$phase_plain rev-$rev: add fake camera source
  phase-$phase_plain rev-$rev: wire frame model into adapters
EOF
exit 1
